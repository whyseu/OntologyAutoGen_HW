# OpenAI-compatible API configuration
# Supports OpenAI, DeepSeek, Qwen, local vLLM, etc.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Optional: override embedding model (default: paraphrase-multilingual-MiniLM-L12-v2)
# EMBEDDING_MODEL=all-MiniLM-L6-v2
